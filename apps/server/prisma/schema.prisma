generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  TEAM_MEMBER
  MANAGER
  ADMIN
}

enum ReportStatus {
  DRAFT
  SUBMITTED
}

model Role {
  id          String   @id @default(cuid())
  name        RoleName @unique
  description String?
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  passwordHash  String
  roleId        String
  role          Role           @relation(fields: [roleId], references: [id])
  isActive      Boolean        @default(true)
  lastLoginAt   DateTime?
  refreshTokens RefreshToken[]
  weeklyReports WeeklyReport[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([roleId])
  @@index([isActive])
}

model WeeklyReport {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStartDate  DateTime
  weekEndDate    DateTime
  project        String
  tasksCompleted String
  tasksPlanned   String
  blockers       String
  hoursWorked    Decimal?     @db.Decimal(5, 2)
  notes          String?
  status         ReportStatus @default(DRAFT)
  submittedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([userId, project, weekStartDate])
  @@index([userId])
  @@index([project])
  @@index([status])
  @@index([weekStartDate])
  @@index([weekEndDate])
}

model RefreshToken {
  id        String    @id
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  userAgent String?
  ipAddress String?

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}
